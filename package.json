{
  "name": "research-desk",
  "version": "0.1.0",
  "private": true,
  "description": "Research Desk — a personal learning OS for transitioning to RLHF / frontier-lab research engineering.",
  "scripts": {
    "dev": "next dev -p 4747",
    "build": "next build",
    "start": "next start -p 4747",
    "lint": "next lint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lighthouse": "lighthouse http://localhost:4747/ --output=json --output-path=./lighthouse.json --only-categories=performance,accessibility,best-practices,seo --chrome-flags=\"--headless=new --no-sandbox\" --quiet"
  },
  "dependencies": {
    "next": "15.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20.17.12",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.6",
    "jsdom": "^26.0.0",
    "lighthouse": "^13.1.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  },
  "packageManager": "pnpm@10.33.2"
}
